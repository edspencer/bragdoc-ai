# Web app specific environment variables
PAYMENT_TOKEN_REQUIRED="false"

# Marketing Site URL (for legal page links)
NEXT_PUBLIC_MARKETING_SITE_HOST=http://localhost:3101

# BYOK: secret used to encrypt user LLM API keys at rest (AES-256-GCM via HKDF)
# Generate with: openssl rand -base64 32
BYOK_ENCRYPTION_KEY=your-byok-encryption-key-here

# BYOK: set to 'true' for self-hosted deployments so private/internal LLM
# base URLs (e.g. Ollama at http://localhost:11434 or http://192.168.x.x:11434)
# are allowed. Leave unset on hosted deployments (SSRF guard).
BYOK_ALLOW_PRIVATE_BASEURLS=false

# Demo mode toggle for authenticated users
# Set to 'true' to show demo toggle button in sidebar (per-user demo mode)
NEXT_PUBLIC_DEMO_MODE_ENABLED=false
# Set to 'true' to enable demo help dialogs
NEXT_PUBLIC_DEMO_HELP_ENABLED=false

# PostHog Analytics (opt-in for open source deployments)
NEXT_PUBLIC_POSTHOG_ENABLED=false
NEXT_PUBLIC_POSTHOG_KEY=your_posthog_key_here
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
